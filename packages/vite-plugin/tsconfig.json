{
  "compilerOptions": {
    "baseUrl": ".",
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["esnext", "DOM", "WebWorker"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@rollup/plugin-node-resolve": [
        "node_modules/@rollup/plugin-node-resolve/types/index.d.ts"
      ],
      "es-module-lexer": ["node_modules/es-module-lexer/types/lexer.d.ts"],
      "src/*": ["src/node/*"],
      "tests/*": ["tests/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "target": "esnext"
  },
  "include": ["client.d.ts", "index.d.cts", "modules.d.ts", "src", "tests"],
  "exclude": ["node_modules", "tests/templates", "dist", "src/node/archive"]
}
